<?xml version="1.0"?>
<!--
  Mars Rover 0.4-Scale Prototype - Minimal URDF (non-xacro)
  ==========================================================
  Simplified version for quick testing without xacro installed.
  Use rover.urdf.xacro for the full parametric model.

  This file contains the same TF tree and geometry but with all
  xacro macros expanded and values hardcoded.

  Total mass: ~1.1 kg
  Colours: Catppuccin Mocha palette
-->
<robot name="mars_rover">

  <!-- ==================== MATERIALS ==================== -->
  <material name="surface0">
    <color rgba="0.192 0.196 0.267 1.0" />
  </material>
  <material name="overlay0">
    <color rgba="0.424 0.439 0.525 1.0" />
  </material>
  <material name="surface1">
    <color rgba="0.271 0.278 0.353 1.0" />
  </material>
  <material name="catppuccin_red">
    <color rgba="0.953 0.545 0.659 1.0" />
  </material>

  <!-- ==================== BASE LINK ==================== -->
  <link name="base_link">
    <visual>
      <origin xyz="0 0 0.005" rpy="0 0 0" />
      <geometry><sphere radius="0.005" /></geometry>
      <material name="catppuccin_red" />
    </visual>
    <inertial>
      <mass value="0.001" />
      <inertia ixx="1e-7" ixy="0" ixz="0" iyy="1e-7" iyz="0" izz="1e-7" />
    </inertial>
  </link>

  <!-- ==================== BASE FOOTPRINT ==================== -->
  <link name="base_footprint">
    <inertial>
      <mass value="0.001" />
      <inertia ixx="1e-7" ixy="0" ixz="0" iyy="1e-7" iyz="0" izz="1e-7" />
    </inertial>
  </link>
  <joint name="base_footprint_joint" type="fixed">
    <parent link="base_link" />
    <child link="base_footprint" />
    <origin xyz="0 0 0" rpy="0 0 0" />
  </joint>

  <!-- ==================== CHASSIS ==================== -->
  <!-- Body: 0.440 x 0.260 x 0.080 m, centre at Z=0.100 -->
  <link name="chassis">
    <visual>
      <geometry><box size="0.440 0.260 0.080" /></geometry>
      <material name="surface0" />
    </visual>
    <collision>
      <geometry><box size="0.440 0.260 0.080" /></geometry>
    </collision>
    <inertial>
      <mass value="0.45" />
      <inertia ixx="0.000303" ixy="0" ixz="0"
               iyy="0.002773" iyz="0"
               izz="0.002773" />
    </inertial>
  </link>
  <joint name="chassis_joint" type="fixed">
    <parent link="base_link" />
    <child link="chassis" />
    <origin xyz="0 0 0.100" rpy="0 0 0" />
  </joint>

  <!-- ==================== LEFT ROCKER ==================== -->
  <link name="left_rocker_link">
    <visual>
      <origin xyz="0 0.090 0" rpy="0 0 0" />
      <geometry><box size="0.020 0.180 0.015" /></geometry>
      <material name="surface1" />
    </visual>
    <collision>
      <origin xyz="0 0.090 0" rpy="0 0 0" />
      <geometry><box size="0.020 0.180 0.015" /></geometry>
    </collision>
    <inertial>
      <mass value="0.03" />
      <inertia ixx="0.0000081" ixy="0" ixz="0"
               iyy="0.0000003" iyz="0"
               izz="0.0000082" />
    </inertial>
  </link>
  <joint name="left_rocker_joint" type="revolute">
    <parent link="chassis" />
    <child link="left_rocker_link" />
    <origin xyz="-0.125 -0.180 -0.040" rpy="0 0 0" />
    <axis xyz="1 0 0" />
    <limit lower="-0.2618" upper="0.2618" effort="5.0" velocity="0.5" />
    <dynamics damping="0.1" friction="0.05" />
  </joint>

  <!-- ==================== LEFT FRONT STEERED WHEEL ==================== -->
  <link name="wheel_fl_steer_link">
    <visual>
      <geometry><cylinder radius="0.008" length="0.020" /></geometry>
      <material name="surface1" />
    </visual>
    <collision>
      <geometry><cylinder radius="0.008" length="0.020" /></geometry>
    </collision>
    <inertial>
      <mass value="0.005" />
      <inertia ixx="1.17e-7" ixy="0" ixz="0" iyy="1.17e-7" iyz="0" izz="1.6e-7" />
    </inertial>
  </link>
  <joint name="wheel_fl_steer_joint" type="revolute">
    <parent link="left_rocker_link" />
    <child link="wheel_fl_steer_link" />
    <origin xyz="-0.015 0.180 -0.020" rpy="0 0 0" />
    <axis xyz="0 0 1" />
    <limit lower="-0.6109" upper="0.6109" effort="2.0" velocity="1.5" />
    <dynamics damping="0.01" friction="0.005" />
  </joint>

  <link name="wheel_fl_link">
    <visual>
      <geometry><cylinder radius="0.040" length="0.032" /></geometry>
      <material name="overlay0" />
    </visual>
    <collision>
      <geometry><cylinder radius="0.040" length="0.032" /></geometry>
    </collision>
    <inertial>
      <mass value="0.04" />
      <inertia ixx="0.0000019" ixy="0" ixz="0"
               iyy="0.0000019" iyz="0"
               izz="0.0000032" />
    </inertial>
  </link>
  <joint name="wheel_fl_link_spin_joint" type="continuous">
    <parent link="wheel_fl_steer_link" />
    <child link="wheel_fl_link" />
    <origin xyz="0 0 0" rpy="1.5708 0 0" />
    <axis xyz="0 0 1" />
    <dynamics damping="0.01" friction="0.005" />
  </joint>

  <!-- ==================== LEFT BOGIE ==================== -->
  <link name="left_bogie_link">
    <visual>
      <geometry><box size="0.018 0.120 0.012" /></geometry>
      <material name="surface1" />
    </visual>
    <collision>
      <geometry><box size="0.018 0.120 0.012" /></geometry>
    </collision>
    <inertial>
      <mass value="0.02" />
      <inertia ixx="0.0000024" ixy="0" ixz="0"
               iyy="0.0000001" iyz="0"
               izz="0.0000025" />
    </inertial>
  </link>
  <joint name="left_bogie_joint" type="revolute">
    <parent link="left_rocker_link" />
    <child link="left_bogie_link" />
    <origin xyz="-0.015 0 -0.010" rpy="0 0 0" />
    <axis xyz="1 0 0" />
    <limit lower="-0.3491" upper="0.3491" effort="5.0" velocity="0.5" />
    <dynamics damping="0.1" friction="0.05" />
  </joint>

  <!-- Left middle wheel (unsteered) -->
  <link name="wheel_ml_link">
    <visual>
      <geometry><cylinder radius="0.040" length="0.032" /></geometry>
      <material name="overlay0" />
    </visual>
    <collision>
      <geometry><cylinder radius="0.040" length="0.032" /></geometry>
    </collision>
    <inertial>
      <mass value="0.04" />
      <inertia ixx="0.0000019" ixy="0" ixz="0"
               iyy="0.0000019" iyz="0"
               izz="0.0000032" />
    </inertial>
  </link>
  <joint name="wheel_ml_spin_joint" type="continuous">
    <parent link="left_bogie_link" />
    <child link="wheel_ml_link" />
    <origin xyz="0 0.060 -0.010" rpy="1.5708 0 0" />
    <axis xyz="0 0 1" />
    <dynamics damping="0.01" friction="0.005" />
  </joint>

  <!-- Left rear steered wheel -->
  <link name="wheel_rl_steer_link">
    <visual>
      <geometry><cylinder radius="0.008" length="0.020" /></geometry>
      <material name="surface1" />
    </visual>
    <collision>
      <geometry><cylinder radius="0.008" length="0.020" /></geometry>
    </collision>
    <inertial>
      <mass value="0.005" />
      <inertia ixx="1.17e-7" ixy="0" ixz="0" iyy="1.17e-7" iyz="0" izz="1.6e-7" />
    </inertial>
  </link>
  <joint name="wheel_rl_steer_joint" type="revolute">
    <parent link="left_bogie_link" />
    <child link="wheel_rl_steer_link" />
    <origin xyz="0 -0.060 -0.010" rpy="0 0 0" />
    <axis xyz="0 0 1" />
    <limit lower="-0.6109" upper="0.6109" effort="2.0" velocity="1.5" />
    <dynamics damping="0.01" friction="0.005" />
  </joint>

  <link name="wheel_rl_link">
    <visual>
      <geometry><cylinder radius="0.040" length="0.032" /></geometry>
      <material name="overlay0" />
    </visual>
    <collision>
      <geometry><cylinder radius="0.040" length="0.032" /></geometry>
    </collision>
    <inertial>
      <mass value="0.04" />
      <inertia ixx="0.0000019" ixy="0" ixz="0"
               iyy="0.0000019" iyz="0"
               izz="0.0000032" />
    </inertial>
  </link>
  <joint name="wheel_rl_link_spin_joint" type="continuous">
    <parent link="wheel_rl_steer_link" />
    <child link="wheel_rl_link" />
    <origin xyz="0 0 0" rpy="1.5708 0 0" />
    <axis xyz="0 0 1" />
    <dynamics damping="0.01" friction="0.005" />
  </joint>

  <!-- ==================== RIGHT ROCKER ==================== -->
  <link name="right_rocker_link">
    <visual>
      <origin xyz="0 0.090 0" rpy="0 0 0" />
      <geometry><box size="0.020 0.180 0.015" /></geometry>
      <material name="surface1" />
    </visual>
    <collision>
      <origin xyz="0 0.090 0" rpy="0 0 0" />
      <geometry><box size="0.020 0.180 0.015" /></geometry>
    </collision>
    <inertial>
      <mass value="0.03" />
      <inertia ixx="0.0000081" ixy="0" ixz="0"
               iyy="0.0000003" iyz="0"
               izz="0.0000082" />
    </inertial>
  </link>
  <joint name="right_rocker_joint" type="revolute">
    <parent link="chassis" />
    <child link="right_rocker_link" />
    <origin xyz="0.125 -0.180 -0.040" rpy="0 0 0" />
    <axis xyz="1 0 0" />
    <limit lower="-0.2618" upper="0.2618" effort="5.0" velocity="0.5" />
    <dynamics damping="0.1" friction="0.05" />
  </joint>

  <!-- ==================== RIGHT FRONT STEERED WHEEL ==================== -->
  <link name="wheel_fr_steer_link">
    <visual>
      <geometry><cylinder radius="0.008" length="0.020" /></geometry>
      <material name="surface1" />
    </visual>
    <collision>
      <geometry><cylinder radius="0.008" length="0.020" /></geometry>
    </collision>
    <inertial>
      <mass value="0.005" />
      <inertia ixx="1.17e-7" ixy="0" ixz="0" iyy="1.17e-7" iyz="0" izz="1.6e-7" />
    </inertial>
  </link>
  <joint name="wheel_fr_steer_joint" type="revolute">
    <parent link="right_rocker_link" />
    <child link="wheel_fr_steer_link" />
    <origin xyz="0.015 0.180 -0.020" rpy="0 0 0" />
    <axis xyz="0 0 1" />
    <limit lower="-0.6109" upper="0.6109" effort="2.0" velocity="1.5" />
    <dynamics damping="0.01" friction="0.005" />
  </joint>

  <link name="wheel_fr_link">
    <visual>
      <geometry><cylinder radius="0.040" length="0.032" /></geometry>
      <material name="overlay0" />
    </visual>
    <collision>
      <geometry><cylinder radius="0.040" length="0.032" /></geometry>
    </collision>
    <inertial>
      <mass value="0.04" />
      <inertia ixx="0.0000019" ixy="0" ixz="0"
               iyy="0.0000019" iyz="0"
               izz="0.0000032" />
    </inertial>
  </link>
  <joint name="wheel_fr_link_spin_joint" type="continuous">
    <parent link="wheel_fr_steer_link" />
    <child link="wheel_fr_link" />
    <origin xyz="0 0 0" rpy="1.5708 0 0" />
    <axis xyz="0 0 1" />
    <dynamics damping="0.01" friction="0.005" />
  </joint>

  <!-- ==================== RIGHT BOGIE ==================== -->
  <link name="right_bogie_link">
    <visual>
      <geometry><box size="0.018 0.120 0.012" /></geometry>
      <material name="surface1" />
    </visual>
    <collision>
      <geometry><box size="0.018 0.120 0.012" /></geometry>
    </collision>
    <inertial>
      <mass value="0.02" />
      <inertia ixx="0.0000024" ixy="0" ixz="0"
               iyy="0.0000001" iyz="0"
               izz="0.0000025" />
    </inertial>
  </link>
  <joint name="right_bogie_joint" type="revolute">
    <parent link="right_rocker_link" />
    <child link="right_bogie_link" />
    <origin xyz="0.015 0 -0.010" rpy="0 0 0" />
    <axis xyz="1 0 0" />
    <limit lower="-0.3491" upper="0.3491" effort="5.0" velocity="0.5" />
    <dynamics damping="0.1" friction="0.05" />
  </joint>

  <!-- Right middle wheel (unsteered) -->
  <link name="wheel_mr_link">
    <visual>
      <geometry><cylinder radius="0.040" length="0.032" /></geometry>
      <material name="overlay0" />
    </visual>
    <collision>
      <geometry><cylinder radius="0.040" length="0.032" /></geometry>
    </collision>
    <inertial>
      <mass value="0.04" />
      <inertia ixx="0.0000019" ixy="0" ixz="0"
               iyy="0.0000019" iyz="0"
               izz="0.0000032" />
    </inertial>
  </link>
  <joint name="wheel_mr_spin_joint" type="continuous">
    <parent link="right_bogie_link" />
    <child link="wheel_mr_link" />
    <origin xyz="0 0.060 -0.010" rpy="1.5708 0 0" />
    <axis xyz="0 0 1" />
    <dynamics damping="0.01" friction="0.005" />
  </joint>

  <!-- Right rear steered wheel -->
  <link name="wheel_rr_steer_link">
    <visual>
      <geometry><cylinder radius="0.008" length="0.020" /></geometry>
      <material name="surface1" />
    </visual>
    <collision>
      <geometry><cylinder radius="0.008" length="0.020" /></geometry>
    </collision>
    <inertial>
      <mass value="0.005" />
      <inertia ixx="1.17e-7" ixy="0" ixz="0" iyy="1.17e-7" iyz="0" izz="1.6e-7" />
    </inertial>
  </link>
  <joint name="wheel_rr_steer_joint" type="revolute">
    <parent link="right_bogie_link" />
    <child link="wheel_rr_steer_link" />
    <origin xyz="0 -0.060 -0.010" rpy="0 0 0" />
    <axis xyz="0 0 1" />
    <limit lower="-0.6109" upper="0.6109" effort="2.0" velocity="1.5" />
    <dynamics damping="0.01" friction="0.005" />
  </joint>

  <link name="wheel_rr_link">
    <visual>
      <geometry><cylinder radius="0.040" length="0.032" /></geometry>
      <material name="overlay0" />
    </visual>
    <collision>
      <geometry><cylinder radius="0.040" length="0.032" /></geometry>
    </collision>
    <inertial>
      <mass value="0.04" />
      <inertia ixx="0.0000019" ixy="0" ixz="0"
               iyy="0.0000019" iyz="0"
               izz="0.0000032" />
    </inertial>
  </link>
  <joint name="wheel_rr_link_spin_joint" type="continuous">
    <parent link="wheel_rr_steer_link" />
    <child link="wheel_rr_link" />
    <origin xyz="0 0 0" rpy="1.5708 0 0" />
    <axis xyz="0 0 1" />
    <dynamics damping="0.01" friction="0.005" />
  </joint>

  <!-- ==================== DIFFERENTIAL BAR ==================== -->
  <link name="differential_bar_link">
    <visual>
      <origin xyz="0 0 0" rpy="1.5708 0 0" />
      <geometry><cylinder radius="0.005" length="0.200" /></geometry>
      <material name="surface1" />
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="1.5708 0 0" />
      <geometry><cylinder radius="0.005" length="0.200" /></geometry>
    </collision>
    <inertial>
      <mass value="0.02" />
      <inertia ixx="0.0000067" ixy="0" ixz="0"
               iyy="0.0000067" iyz="0"
               izz="0.00000003" />
    </inertial>
  </link>
  <joint name="differential_bar_joint" type="fixed">
    <parent link="chassis" />
    <child link="differential_bar_link" />
    <origin xyz="0 0 0.045" rpy="0 0 0" />
  </joint>

  <!-- ==================== SENSOR LINKS (Phase 2) ==================== -->
  <!-- All sensors are empty links with small visual markers -->

  <!-- LiDAR: top of body, centre -->
  <link name="lidar_link">
    <visual><geometry><sphere radius="0.008" /></geometry><material name="catppuccin_red" /></visual>
    <inertial><mass value="0.001" /><inertia ixx="1e-7" ixy="0" ixz="0" iyy="1e-7" iyz="0" izz="1e-7" /></inertial>
  </link>
  <joint name="lidar_link_joint" type="fixed">
    <parent link="chassis" />
    <child link="lidar_link" />
    <origin xyz="0 0 -0.015" rpy="0 0 0" />
  </joint>

  <!-- IMU: centre of body -->
  <link name="imu_link">
    <visual><geometry><sphere radius="0.008" /></geometry><material name="catppuccin_red" /></visual>
    <inertial><mass value="0.001" /><inertia ixx="1e-7" ixy="0" ixz="0" iyy="1e-7" iyz="0" izz="1e-7" /></inertial>
  </link>
  <joint name="imu_link_joint" type="fixed">
    <parent link="chassis" />
    <child link="imu_link" />
    <origin xyz="0 0 -0.010" rpy="0 0 0" />
  </joint>

  <!-- GPS: top deck rear -->
  <link name="gps_link">
    <visual><geometry><sphere radius="0.008" /></geometry><material name="catppuccin_red" /></visual>
    <inertial><mass value="0.001" /><inertia ixx="1e-7" ixy="0" ixz="0" iyy="1e-7" iyz="0" izz="1e-7" /></inertial>
  </link>
  <joint name="gps_link_joint" type="fixed">
    <parent link="chassis" />
    <child link="gps_link" />
    <origin xyz="0 -0.100 -0.015" rpy="0 0 0" />
  </joint>

  <!-- Front camera -->
  <link name="camera_front">
    <visual><geometry><sphere radius="0.008" /></geometry><material name="catppuccin_red" /></visual>
    <inertial><mass value="0.001" /><inertia ixx="1e-7" ixy="0" ixz="0" iyy="1e-7" iyz="0" izz="1e-7" /></inertial>
  </link>
  <joint name="camera_front_joint" type="fixed">
    <parent link="chassis" />
    <child link="camera_front" />
    <origin xyz="0 0.220 0.010" rpy="0 0 0" />
  </joint>

  <!-- Rear camera -->
  <link name="camera_rear">
    <visual><geometry><sphere radius="0.008" /></geometry><material name="catppuccin_red" /></visual>
    <inertial><mass value="0.001" /><inertia ixx="1e-7" ixy="0" ixz="0" iyy="1e-7" iyz="0" izz="1e-7" /></inertial>
  </link>
  <joint name="camera_rear_joint" type="fixed">
    <parent link="chassis" />
    <child link="camera_rear" />
    <origin xyz="0 -0.220 0.010" rpy="0 0 3.14159" />
  </joint>

  <!-- Left camera -->
  <link name="camera_left">
    <visual><geometry><sphere radius="0.008" /></geometry><material name="catppuccin_red" /></visual>
    <inertial><mass value="0.001" /><inertia ixx="1e-7" ixy="0" ixz="0" iyy="1e-7" iyz="0" izz="1e-7" /></inertial>
  </link>
  <joint name="camera_left_joint" type="fixed">
    <parent link="chassis" />
    <child link="camera_left" />
    <origin xyz="-0.130 0 0.010" rpy="0 0 1.5708" />
  </joint>

  <!-- Right camera -->
  <link name="camera_right">
    <visual><geometry><sphere radius="0.008" /></geometry><material name="catppuccin_red" /></visual>
    <inertial><mass value="0.001" /><inertia ixx="1e-7" ixy="0" ixz="0" iyy="1e-7" iyz="0" izz="1e-7" /></inertial>
  </link>
  <joint name="camera_right_joint" type="fixed">
    <parent link="chassis" />
    <child link="camera_right" />
    <origin xyz="0.130 0 0.010" rpy="0 0 -1.5708" />
  </joint>

  <!-- Depth camera (OAK-D Lite) -->
  <link name="depth_camera">
    <visual><geometry><sphere radius="0.008" /></geometry><material name="catppuccin_red" /></visual>
    <inertial><mass value="0.001" /><inertia ixx="1e-7" ixy="0" ixz="0" iyy="1e-7" iyz="0" izz="1e-7" /></inertial>
  </link>
  <joint name="depth_camera_joint" type="fixed">
    <parent link="chassis" />
    <child link="depth_camera" />
    <origin xyz="0 0.200 0.020" rpy="0 0 0" />
  </joint>

</robot>
