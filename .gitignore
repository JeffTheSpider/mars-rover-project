# Mars Rover Project .gitignore

# === Build artifacts ===
firmware/esp32/build/
*.elf
*.bin
*.hex
*.map

# === Arduino/PlatformIO ===
.pio/
.vscode/
*.d

# === Python ===
__pycache__/
*.pyc
*.pyo
*.egg-info/
dist/
build/
*.egg

# === ROS2 ===
software/jetson/build/
software/jetson/install/
software/jetson/log/
*.bag
*.db3
*.db3-wal
*.db3-shm

# === Node.js ===
node_modules/

# === CAD ===
# Keep exported STLs, ignore Fusion 360 temp files
*.f3d.bak
*.step.bak
*.f3z

# === Gazebo ===
.gazebo/

# === 3D Printing ===
# Keep STLs, ignore sliced/converted files
*.3mf.bak
*.x3g
*.gcode
3d-print/gcode/

# === OS ===
.DS_Store
Thumbs.db
desktop.ini
*.swp
*.swo
*~

# === IDE ===
.idea/
*.code-workspace

# === Secrets ===
.env
*.pem
*.key

# === Temporary ===
*.tmp
*.log
*.bak
temp/

# === MCP / Vendor tools (large, install locally) ===
tools/cadquery-mcp/
tools/kicad-mcp/
tools/math-mcp/
cad/cadquery-mcp-server-rishi/
cad/mcp-cadquery-bert/
cad/fusion-mcp/
cad/mcp-link-server/
cad/reference/
.mcp.json

# === Fusion 360 UI screenshots (debug only) ===
cad/*.png
cad/fusion360_*.png
cad/f360_*.png
cad/scripts_*.png
cad/batch_*.png
cad/fusion_*.png

# === Temporary screenshots (root) ===
temp_*.png

# === Claude Code local config ===
.claude/settings.local.json

# === Test/CI ===
.pytest_cache/
firmware-test-results.xml
htmlcov/
.coverage
# Large files (>100MB GitHub limit)
cad/reference-wheels/curiosity-mars-rover-wheel-1.snapshot.2.zip
cad/reference=suspension/extracted/0.4-scale/full_rover_assembly_04x.stl
3d-print/reference-suspension/rover_suspension_wheels_0.4x.stl
cad/reference=suspension/extracted/0.4-scale/rover_suspension_wheels_0.4x.stl
